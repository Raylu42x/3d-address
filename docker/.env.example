# Copy to .env and edit. Used by docker-compose.yml (and referenced by the host
# Caddyfile for the two public domains). Every deployment-specific value lives
# here — nothing is hardcoded in the app.

# ---- Public domains (host Caddy reverse proxy) ----
FRONTEND_DOMAIN=address.kervian.com
API_DOMAIN=api.kervian.com

# ---- Frontend -> backend wiring ----
# Public API origin the browser calls for all /v1 requests. In production this
# must be https://<API_DOMAIN>. Written into config.js at container start.
API_BASE=https://api.kervian.com

# Public site origin (the frontend's own URL). Used for SEO absolute URLs —
# canonical link, Open Graph/Twitter image, and sitemap. Set to https://<FRONTEND_DOMAIN>.
SITE_URL=https://address.kervian.com

# ---- Backend CORS ----
# Comma-separated allowlist of origins allowed to call the API. Set to the
# frontend origin in production. Leave empty for "*" (open). No credentials.
CORS_ORIGINS=https://address.kervian.com

# ---- Backend rate limiting (slowapi, keyed by client IP) ----
# Master switch; set false to disable all limits (trusted/self-host).
RATE_LIMIT_ENABLED=true
# Protocol endpoints (encode/decode/alternatives) are cheap & stateless.
# Empty = unlimited. Example to cap: 120/minute
RATE_LIMIT_PROTOCOL=
# Geocode/reverse/suggest proxy public OSM services (strict usage policies).
RATE_LIMIT_GEOCODE=1/second

# ---- Geocoding upstreams ----
GEOCODER_ENABLED=true
NOMINATIM_URL=https://nominatim.openstreetmap.org
PHOTON_URL=https://photon.komoot.io
GEO_USER_AGENT=WordAddressProtocol/0.2 (self-hosted)
